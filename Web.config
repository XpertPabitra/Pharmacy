<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<add name="PharmacyDB"
     connectionString="Data Source=.;Initial Catalog=PharmacyDB;User ID=sa;Password=mcc#1234"
     providerName="System.Data.SqlClient" />
	</connectionStrings>
	<appSettings>
		<add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
	</appSettings>

	<system.web>
		<compilation debug="true" targetFramework="4.8.1" />
		<httpRuntime targetFramework="4.8.1" />
		<sessionState mode="InProc" timeout="30" />
	</system.web>

	<system.webServer>
		<defaultDocument>
			<files>
				<add value="Login.aspx" />
			</files>
		</defaultDocument>
	</system.webServer>
</configuration>